{
  "name": "NekoVault",
  "version": "1.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "d1:create": "wrangler d1 create nekovault-db",
    "d1:init-local": "wrangler d1 execute nekovault-db --local --file=server/database/schema.sql",
    "d1:init-remote": "wrangler d1 execute nekovault-db --remote --file=server/database/schema.sql"
  },
  "dependencies": {
    "@faker-js/faker": "^9.8.0",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/simple-icons": "^1.2.78",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "^0.11.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "otpauth": "^9.5.0",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^22.19.17",
    "@types/sortablejs": "^1.15.9",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.33.0"
}
